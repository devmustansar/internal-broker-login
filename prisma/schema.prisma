generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String
  role                String   // "super_admin" | "admin" | "user" | "readonly"
  allowedResourceKeys String[] // ["*"] means all
  passwordHash        String?  // nullable for mock login/SSO
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  auditLogs           AuditLog[]
  sessions            BrokerSession[]
  organizations       UserOrganization[]
  awsPolicies         UserAwsPolicy[]
  credentialGroupMemberships CredentialGroupMember[]
  credentialShares           CredentialShare[]
}

model Resource {
  id             String   @id @default(uuid())
  resourceKey    String   @unique
  name           String
  appHost        String
  apiHost        String
  loginUrl       String
  loginMethod    String   @default("POST")
  loginAdapter   String   // "form_login_basic" | "form_login_csrf" | "json_login" | "magic_link"
  tokenExtractionPath    String? // JSON path to the one-time token in the login response, e.g. "info.token"
  tokenValidationPath    String? // client app path that validates the one-time token, e.g. "/auth/validate"
  /// For magic_link adapter: JSON path to the redirect URL in the login response, e.g. "data.url" or "link".
  /// When set, the broker extracts this URL from the login response and redirects the user directly to it,
  /// bypassing the normal one-time-token + tokenValidationPath flow entirely.
  magicLinkExtractionPath String?
  /// Optional JSON template for the login request body.
  /// Supports {{email}} and {{password}} placeholders (replaced at runtime).
  /// Any extra static fields in the template are preserved as-is.
  /// Example: {"user_params":{"email":"{{email}}","password":"{{password}}","external_login_url":true}}
  /// When blank, the broker sends a flat {[usernameField]: email, [passwordField]: password} body.
  loginPayloadTemplate   String?
  usernameField  String?  // e.g. "email" or "user_id"
  passwordField  String?  // e.g. "password" or "passAuth"
  environment    String   @default("production")
  isActive       Boolean  @default(true)
  description    String?
  iconUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  accounts       ManagedAccount[]
  sessions       BrokerSession[]
  auditLogs      AuditLog[]
}

model ManagedAccount {
  id          String   @id @default(uuid())
  resource    Resource @relation(fields: [resourceId], references: [id])
  resourceId  String
  accountKey  String
  vaultPath   String
  label       String
  role        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    BrokerSession[]
}

model BrokerSession {
  brokerSessionId  String   @id @default(uuid())
  user             User     @relation(fields: [userId], references: [id])
  userId           String
  resource         Resource @relation(fields: [resourceId], references: [id])
  resourceId       String
  managedAccount   ManagedAccount @relation(fields: [managedAccountId], references: [id])
  managedAccountId String
  upstreamCookies  Json     // Map<string, string>
  status           String   @default("active")
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  auditLogs        AuditLog[]
}

model AuditLog {
  id               String   @id @default(uuid())
  action           String
  user             User?    @relation(fields: [userId], references: [id])
  userId           String?
  /// Denormalized for fast filtering — mirrors Resource.resourceKey at log time
  resourceKey      String?
  resource         Resource? @relation(fields: [resourceId], references: [id])
  resourceId       String?
  brokerSession    BrokerSession? @relation(fields: [brokerSessionId], references: [brokerSessionId])
  brokerSessionId  String?
  /// Denormalized org scope at log time — enables org-scoped admin queries
  organizationId   String?
  timestamp        DateTime @default(now())
  details          Json?
  ipAddress        String?
  outcome          String   // "success" | "failure" | "info"

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([outcome])
  @@index([timestamp])
  @@index([resourceKey])
}

// ─── Secrets Management ───────────────────────────────────────────────────────
//
// StoredSecret       — one row per live secret (payload is AES-256-GCM ciphertext)
// StoredSecretRef    — routing table used by HybridSecretsProvider
//
// Design principles:
//   • encryptedPayload is the ONLY column that holds sensitive data
//   • All other columns are audit-safe and may appear in logs
//   • deletedAt == null means the row is live (soft-delete pattern)
//   • version increments on every updateSecret() call

model StoredSecret {
  id               String    @id @default(uuid())

  /// Logical reference key used in resource config, e.g. "aws/broker/default"
  /// Unique among non-deleted rows (enforced in application layer via unique index)
  secretRef        String    @unique

  /// SecretKind discriminant: aws_iam_credentials | web_basic_credentials | jira_api_token | generic_key_value
  kind             String

  /// AES-256-GCM ciphertext — format: "<iv_hex>:<authTag_hex>:<ciphertext_hex>"
  /// Never logged, never returned to the frontend
  encryptedPayload String

  /// Audit-safe metadata (label, resourceKey, tags, notes, rotatedAt)
  /// Stored as JSONB — never contains plaintext credentials
  metadata         Json      @default("{}")

  /// Which provider type created this row ("database" | "vault")
  provider         String    @default("database")

  /// Optimistic concurrency counter — incremented on each updateSecret()
  version          Int       @default(1)

  /// Soft-delete timestamp — null means the secret is live
  deletedAt        DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([secretRef])
  @@index([kind])
  @@index([deletedAt])
}

/// Routing table for HybridSecretsProvider.
/// Maps each secretRef → which backend (database | vault) owns it.
/// Only needed in hybrid mode; safe to ignore in single-provider deployments.
model StoredSecretRef {
  id        String    @id @default(uuid())
  secretRef String    @unique

  /// "database" or "vault"
  provider  String

  /// Mirrors soft-delete state of the corresponding StoredSecret
  deletedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── AWS Federation ───────────────────────────────────────────────────────────

model AwsResource {
  id                   String   @id @default(uuid())
  /// Unique key used in portal ACL checks, e.g. "aws-prod-readonly"
  resourceKey          String   @unique
  name                 String
  description          String?
  /// AWS account ID for display purposes, e.g. "123456789012"
  awsAccountId         String
  /// IAM Role ARN the broker will assume, e.g. "arn:aws:iam::123456789012:role/BrokerConsoleRole"
  roleArn              String
  /// AWS region, e.g. "us-east-1"
  region               String   @default("us-east-1")
  /// AWS Console destination URL after sign-in, e.g. "https://console.aws.amazon.com/"
  destination          String   @default("https://console.aws.amazon.com/")
  /// Issuer label in CloudTrail, e.g. "internal-broker"
  issuer               String   @default("internal-broker")
  /// Custom STS session name used in CloudTrail instead of the user's email.
  /// If empty, the authenticated user's email is used (sanitized to STS format).
  /// Max 64 chars, allowed: [a-zA-Z0-9+=,.@_-]
  sessionName          String?
  /// STS session duration in seconds. Min 900, max 43200.
  sessionDurationSeconds Int    @default(3600)
  /// Optional external ID for cross-account trust policy
  externalId           String?
  /// Key used to look up broker IAM credentials from SecretsProvider, e.g. "aws/broker/default"
  brokerCredentialRef  String
  /// "assume_role" (preferred) or "federation_token" (fallback)
  stsStrategy          String   @default("assume_role")
  /// IAM managed policy ARNs available for selection when assigning this resource to users
  availablePolicyArns  String[]
  /// Whether this resource appears in the portal
  isActive             Boolean  @default(true)
  /// Environment tag for display
  environment          String   @default("production")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization         Organization? @relation(fields: [organizationId], references: [id])
  organizationId       String?

  userPolicies         UserAwsPolicy[]
}

/// Per-user session policy selections for AWS resources.
/// When a user launches an AWS resource, the policyArns stored here are
/// passed to STS AssumeRole/GetFederationToken as session policies,
/// scoping down the assumed role's permissions for that specific user.
model UserAwsPolicy {
  id           String      @id @default(uuid())
  user         User        @relation(fields: [userId], references: [id])
  userId       String
  awsResource  AwsResource @relation(fields: [awsResourceId], references: [id])
  awsResourceId String
  /// IAM managed policy ARNs to attach as session policies
  policyArns   String[]
  /// Custom session name for CloudTrail identity (optional, max 64 chars)
  sessionName  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([userId, awsResourceId])
}

// ─── Multi-Tenancy ───────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users             UserOrganization[]
  resources         Resource[]
  awsResources      AwsResource[]
  sharedCredentials SharedCredential[]
  credentialGroups  CredentialGroup[]
}

model UserOrganization {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  /// Organization-scoped role: "owner" | "admin" | "member"
  /// Owners can manage org settings + promote admins.
  /// Admins can manage resources and members within the org.
  /// Members have read-only org access (resource access via allowedResourceKeys).
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

// ─── Credential Manager ──────────────────────────────────────────────────────
//
// SharedCredential  — an encrypted credential record (app name, URL, username/password)
// CredentialGroup   — a named collection of credentials for bulk sharing
// CredentialGroupEntry   — M:N join between credentials and groups
// CredentialGroupMember  — M:N join between groups and users (dev gets all creds in group)
// CredentialShare   — direct 1:1 share of a single credential with a user

model SharedCredential {
  id               String   @id @default(uuid())
  appName          String
  loginUrl         String?
  description      String?
  /// AES-256-GCM encrypted JSON: {"username":"...","password":"..."}
  encryptedPayload String
  organization     Organization @relation(fields: [organizationId], references: [id])
  organizationId   String
  /// userId of the admin who created this credential
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  groups           CredentialGroupEntry[]
  shares           CredentialShare[]

  @@index([organizationId])
}

model CredentialGroup {
  id             String   @id @default(uuid())
  name           String
  description    String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  /// userId of the admin who created this group
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  credentials    CredentialGroupEntry[]
  members        CredentialGroupMember[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model CredentialGroupEntry {
  id           String           @id @default(uuid())
  credential   SharedCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  credentialId String
  group        CredentialGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String
  createdAt    DateTime         @default(now())

  @@unique([credentialId, groupId])
}

model CredentialGroupMember {
  id        String          @id @default(uuid())
  group     CredentialGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   String
  user      User            @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime        @default(now())

  @@unique([groupId, userId])
}

model CredentialShare {
  id           String           @id @default(uuid())
  credential   SharedCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  credentialId String
  user         User             @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime         @default(now())

  @@unique([credentialId, userId])
}
